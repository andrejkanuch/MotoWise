{
  "name": "@motovault/api",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch --exec tsx",
    "start": "node dist/src/main.js",
    "start:debug": "nest start --debug --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "generate:schema": "ts-node --transpile-only scripts/generate-schema.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@apollo/server": "^4.11.0",
    "@as-integrations/express5": "^1.1.2",
    "@motovault/types": "workspace:*",
    "@nestjs/apollo": "^13.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.0.0",
    "@supabase/supabase-js": "^2.98.0",
    "graphql": "^16.10.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-type-json": "^0.3.2",
    "helmet": "^8.0.0",
    "jose": "^6.0.0",
    "openai": "^6.29.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^4.0.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@motovault/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/graphql-depth-limit": "^1.1.0",
    "@types/graphql-type-json": "^0.3.5",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
