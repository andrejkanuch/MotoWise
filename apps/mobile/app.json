{
  "expo": {
    "name": "MotoLearn",
    "slug": "motolearn",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "motowise",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "MotoLearn needs camera access for diagnostic photo capture."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MotoLearn needs photo library access to upload diagnostic images."
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#FF6B35"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.motolearn.app",
      "supportsTablet": true,
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.motolearn.app",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#1b2e4b"
      }
    }
  }
}
